---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { 
  title, 
  description = "Senior Software Engineer with 9+ years building high-scale distributed systems. Expert in Go, Kubernetes, AWS, Kafka, microservices architecture.",
  image = "/og-image.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://faizalpribadi.github.io');
const fullImageURL = new URL(image, 'https://faizalpribadi.github.io');
const siteName = "Faizal Pribadi";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Core Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Faizal Pribadi" />
    <meta name="keywords" content="Senior Software Engineer, Go, Kubernetes, AWS, Kafka, Distributed Systems, Microservices, Indonesia, Bogor, Backend Engineer, Faizal Pribadi" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:article:author" content="Faizal Pribadi" />
    <meta property="og:article:published_time" content="2025-05-11T00:00:00+00:00" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageURL} />
    <meta name="twitter:creator" content="@faizalpribadi" />
    <meta name="twitter:site" content="@faizalpribadi" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#1e1e2e" />
    <meta name="msapplication-TileColor" content="#1e1e2e" />
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Faizal Pribadi - RSS Feed" href="/rss.xml" />
    
    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Faizal Pribadi",
      "jobTitle": "Senior Software Engineer",
      "url": "https://faizalpribadi.github.io",
      "email": "mailto:faizal.pribadi@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bogor",
        "addressCountry": "ID"
      },
      "sameAs": [
        "https://github.com/faizalpribadi",
        "https://linkedin.com/in/faizal-pribadi"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Bukumed"
      },
      "knowsAbout": [
        "Go",
        "Kubernetes",
        "AWS",
        "Kafka",
        "Distributed Systems",
        "Microservices"
      ]
    })} />
    
    <slot name="head" />
  </head>
  <body>
    <div class="terminal">
      <div class="terminal-header">
        <div class="terminal-buttons">
          <span class="terminal-btn close"></span>
          <span class="terminal-btn minimize"></span>
          <span class="terminal-btn maximize"></span>
        </div>
        <div class="terminal-title">faizal@portfolio ~ {title.toLowerCase()}</div>
      </div>
      <div class="terminal-body">
        <slot />
      </div>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>